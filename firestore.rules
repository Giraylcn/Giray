rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Reset
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Entity Specific Validations
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.code is string && data.code.size() == 6 &&
             data.createdAt is timestamp;
    }

    function isValidFriend(data) {
      return data.code is string && data.code.size() == 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.addedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.fromUid == request.auth.uid &&
             data.fromName is string && data.fromName.size() > 0 &&
             data.message is string && data.message.size() <= 5000 &&
             data.timestamp == request.time &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000000));
    }

    // 4. Match Blocks

    match /users/{userId} {
      // Users can look up each other by UID if they know it (to display name in chat), 
      // but listing all users is prohibited.
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().uid == existing().uid && 
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name']);
      
      match /friends/{friendId} {
        allow read, write: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFriend(incoming()) && incoming().addedAt == request.time;
      }
    }

    match /chats/{chatId} {
      // chatId pattern: uid1_uid2
      function isChatParticipant(cid) {
        return isSignedIn() && (request.auth.uid in cid.split('_'));
      }

      allow get: if isChatParticipant(chatId);
      
      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId) && isValidMessage(incoming());
      }
    }
    
    // Explicit deny for any other patterns
    match /test/{docId} {
       allow read: if false;
    }
  }
}
